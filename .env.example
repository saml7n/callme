# ─── Pronto — Environment Variables ───────────────────────────────────
#
# Copy this file to .env and fill in values for local development.
# In production, leave service API keys EMPTY — users enter their own
# credentials through the setup wizard (stored encrypted in the database).
#
# The .env file is a LOCAL DEV CONVENIENCE ONLY. Database values always
# take precedence over these when set.
# ──────────────────────────────────────────────────────────────────────

# ── Required in all environments ──────────────────────────────────────

# API key for dashboard / API authentication (pick any strong secret)
CALLME_API_KEY=

# Server port
PORT=3000

# Public URL where Twilio webhooks can reach this server
# (e.g. https://your-domain.com or an ngrok URL for local dev)
PUBLIC_URL=

# SQLite database path
DATABASE_URL=sqlite:///./callme.db

# ── Auto-generated (leave blank — created on first startup) ──────────

# Fernet encryption key for credential storage. Auto-generated if empty.
# CALLME_ENCRYPTION_KEY=

# ── Local dev only (optional) ────────────────────────────────────────
# These are FALLBACKS — if a user enters keys via the setup wizard,
# those database values take precedence over anything here.

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Deepgram
DEEPGRAM_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI
OPENAI_API_KEY=

# Fallback transfer number for unrecoverable errors mid-call
CALLME_FALLBACK_NUMBER=
